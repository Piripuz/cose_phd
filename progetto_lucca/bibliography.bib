@article{https://doi.org/10.1111/iere.12692,
author = {Hall, Jonathan D.},
title = {Inframarginal Travelers and Transportation Policy},
journal = {International Economic Review},
volume = {65},
number = {3},
pages = {1519-1550},
doi = {https://doi.org/10.1111/iere.12692},
url = {https://onlinelibrary.wiley.com/doi/abs/10.1111/iere.12692},
eprint = {https://onlinelibrary.wiley.com/doi/pdf/10.1111/iere.12692},
abstract = {Abstract Structural models of traffic congestion, such as the bottleneck model, are used to answer important, policy-relevant questions. However, existing models typically assume that no travelers are inframarginal regarding when to travel; that is, given equilibrium travel times, no travelers strictly prefer their ex ante departure time to all others. In this article, I address this shortcoming by incorporating inframarginal travelers into these models. This change significantly improves these models' ability to fit the data and changes policy prescriptions. In the case of congestion pricing, it typically changes the optimal toll by at least 25\% and significantly worsens the distributional impacts.},
year = {2024}
}
