@article{d0907f84-e14a-3d98-ad20-759f41491d6e,
 ISSN = {00028282},
 URL = {http://www.jstor.org/stable/2117502},
 abstract = {This paper considers the modeling of road congestion subject to peak-load demand. The standard model contains ambiguities and is poorly specified. These problems can be eliminated by working with a structural model that explicitly treats the congestion technology and drivers' behavioral decisions. The paper provides a detailed analysis of a particular structural model--William Vickrey's model of bottleneck congestion in the morning rush-hour auto commute, extended to treat elastic (i.e., price-sensitive) demand--and examines some economic implications of the structural approach.},
